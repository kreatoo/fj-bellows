#cloud-config
# Cache VM bootstrap for fj-bellows. Installs zot, writes the
# fjb-managed TLS cert (signed by the persisted CA so workers trust it),
# configures zot's S3 storage driver, and starts the systemd unit.
#
# FJB-13: zot is a scratch registry workers address explicitly. There
# is no sync extension pulling from an upstream registry, and the
# orchestrator does not dial this VM for any reverse-tunnel. Workers
# `docker push/pull cache.fjb.internal:5000/<ref>` directly; pushes
# bound for the canonical registry (Forgejo etc.) go from the worker
# straight to that registry without touching zot.
#
# Bound to 0.0.0.0:5000: the deployment firewall drops public-inbound
# tcp/5000 (only tcp/22 is open per the auto sentinel), and the VPC NIC
# stays reachable from workers within the cache subnet. Operators can
# break-glass via Lish or SSH + a local port-forward.
package_update: true
packages:
  - curl
  - ca-certificates
{{- if .IPTablesScript}}
  - iptables-persistent
{{- end}}
{{- if .OrchestratorWGPubkey}}
  - wireguard
  - awscli
{{- end}}
write_files:
  - path: /etc/zot/config.json
    permissions: '0640'
    content: |
      {
        "distSpecVersion": "1.1.0",
        "storage": {
          "rootDirectory": "/var/lib/zot",
          "dedupe": false,
          "storageDriver": {
            "name": "s3",
            "region": "{{.Region}}",
            "regionendpoint": "{{.Endpoint}}",
            "bucket": "{{.Bucket}}",
            "accesskey": "{{.AccessKey}}",
            "secretkey": "{{.SecretKey}}",
            "secure": true,
            "forcepathstyle": true
          },
          "gc": true
        },
        "http": {
          "address": "0.0.0.0",
          "port": "5000",
          "compat": ["docker2s2"],
          "tls": {
            "cert": "/etc/zot/tls/cert.pem",
            "key": "/etc/zot/tls/key.pem"
          }
        },
        "log": {
          "level": "info"
        }
      }
  - path: /etc/zot/tls/cert.pem
    permissions: '0644'
    content: |
{{.ServerCertPEM | indent 6}}
  - path: /etc/zot/tls/key.pem
    permissions: '0600'
    content: |
{{.ServerKeyPEM | indent 6}}
{{- if .IPTablesScript}}
  - path: /usr/local/sbin/fjb-iptables.sh
    permissions: '0750'
    content: |
{{.IPTablesScript | indent 6}}
{{- end}}
{{- if .OrchestratorWGPubkey}}
  - path: /usr/local/sbin/fjb-wg-bootstrap.sh
    permissions: '0750'
    content: |
      #!/usr/bin/env bash
      # FJB-99 Phase A — cache wg-quick bootstrap.
      # Idempotent: keypair generates once on first boot; subsequent
      # boots reuse the persisted private key. wg0.conf is always
      # rewritten so a config bump (peer pubkey rotation, port change)
      # takes effect on reboot without operator intervention.
      set -euo pipefail
      umask 0077
      install -d -m 0700 /etc/wireguard
      if [ ! -s /etc/wireguard/privatekey ]; then
        wg genkey | tee /etc/wireguard/privatekey | wg pubkey > /etc/wireguard/publickey
        chmod 0600 /etc/wireguard/privatekey
        chmod 0644 /etc/wireguard/publickey
      fi
      priv=$(cat /etc/wireguard/privatekey)
      cat > /etc/wireguard/wg0.conf <<EOC
      [Interface]
      Address = {{.CacheWGAddr}}/32
      ListenPort = {{.WGListenPort}}
      PrivateKey = ${priv}

      [Peer]
      PublicKey = {{.OrchestratorWGPubkey}}
      AllowedIPs = {{.OrchestratorWGAddr}}/32
      PersistentKeepalive = 25
      EOC
      chmod 0600 /etc/wireguard/wg0.conf
      systemctl enable --now wg-quick@wg0
      # Publish own pubkey so the orchestrator can read it via plain
      # HTTPS GET and complete the wg peer config on its side (FJB-99
      # Phase B). WG public keys are designed to be world-readable —
      # exposing one over public-read costs nothing.
      AWS_ACCESS_KEY_ID='{{.AccessKey}}' \
      AWS_SECRET_ACCESS_KEY='{{.SecretKey}}' \
      AWS_DEFAULT_REGION='{{.Region}}' \
        aws --endpoint-url '{{.Endpoint}}' \
            s3 cp /etc/wireguard/publickey \
                  s3://{{.Bucket}}/wg-pubkey.txt \
            --acl public-read
{{- end}}
  - path: /etc/systemd/system/zot.service
    permissions: '0644'
    content: |
      [Unit]
      Description=zot OCI-native container registry
      After=network-online.target
      Wants=network-online.target
      [Service]
      Type=simple
      ExecStart=/usr/local/bin/zot serve /etc/zot/config.json
      Restart=on-failure
      RestartSec=5s
      User=root
      [Install]
      WantedBy=multi-user.target
runcmd:
{{- if .HostPrivateKey}}
  - |
    set -eu
    install -m 0600 /dev/null /etc/ssh/ssh_host_ed25519_key
    printf '%s' '{{.HostPrivateKey | b64enc}}' | base64 -d > /etc/ssh/ssh_host_ed25519_key
    chmod 0600 /etc/ssh/ssh_host_ed25519_key
    ssh-keygen -y -f /etc/ssh/ssh_host_ed25519_key > /etc/ssh/ssh_host_ed25519_key.pub
    chmod 0644 /etc/ssh/ssh_host_ed25519_key.pub
    mkdir -p /etc/ssh/sshd_config.d
    printf 'HostKey /etc/ssh/ssh_host_ed25519_key\n' > /etc/ssh/sshd_config.d/10-fj-bellows-hostkey.conf
    systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || systemctl restart sshd 2>/dev/null || systemctl restart ssh
{{- end}}
  - |
    set -eu
    arch="$(uname -m)"
    case "$arch" in
      x86_64) zarch=amd64 ;;
      aarch64|arm64) zarch=arm64 ;;
      *) echo "unsupported arch: $arch" >&2; exit 1 ;;
    esac
    url="https://github.com/project-zot/zot/releases/download/v{{.ZotVersion}}/zot-linux-${zarch}"
    curl -fsSL -o /usr/local/bin/zot "$url"
    chmod +x /usr/local/bin/zot
  - mkdir -p /var/lib/zot
{{- if .IPTablesScript}}
  - /usr/local/sbin/fjb-iptables.sh
  - netfilter-persistent save
{{- end}}
{{- if .OrchestratorWGPubkey}}
  - /usr/local/sbin/fjb-wg-bootstrap.sh
{{- end}}
  - systemctl daemon-reload
  - systemctl enable --now zot.service
  - touch {{.ReadyFile}}
